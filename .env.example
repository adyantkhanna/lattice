# ─── Auth mode ───────────────────────────────────────────────────────────────
# "local"  → no login UI, single user, SQLite, BYOK (default)
# "multi"  → Auth.js v5, email magic link + GitHub OAuth, Postgres
AUTH_MODE=local

# ─── AI providers ────────────────────────────────────────────────────────────
# Required in local mode (user supplies their own key).
# In multi mode this may be set server-side instead.
ANTHROPIC_API_KEY=

# Required for web search fallback via Exa when a pack has no curated sources.
EXA_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
# Local mode: SQLite file at ./data/lattice.db (created automatically, no config needed).
# Multi mode: Postgres connection string required.
# DATABASE_URL=postgresql://user:password@localhost:5432/lattice

# ─── Auth.js (multi mode only) ───────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# NEXTAUTH_SECRET=

# Email magic link provider (multi mode only)
# EMAIL_SERVER=smtp://user:pass@smtp.example.com:587
# EMAIL_FROM=noreply@example.com

# GitHub OAuth provider (multi mode only)
# GITHUB_ID=
# GITHUB_SECRET=

# ─── App ─────────────────────────────────────────────────────────────────────
# Public base URL — used for Auth.js callbacks in multi mode.
# NEXTAUTH_URL=http://localhost:3000
